---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content="VIOS Collaboratory — AI for Life Sciences"
        />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/vios.science/favicon.svg"
        />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400&family=Outfit:wght@300;400;500;600&family=Spectral:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap"
            rel="stylesheet"
        />

        <script is:inline>
            // Run before page loads to prevent flash of unstyled content
            const theme = (() => {
                if (
                    typeof localStorage !== "undefined" &&
                    localStorage.getItem("vios-theme")
                ) {
                    return localStorage.getItem("vios-theme");
                }
                if (
                    window.matchMedia("(prefers-color-scheme: light)").matches
                ) {
                    return "light";
                }
                return "dark";
            })();

            if (theme === "light") {
                document.documentElement.classList.add("light");
            } else {
                document.documentElement.classList.remove("light");
            }
            window.localStorage.setItem("vios-theme", theme);
        </script>
    </head>
    <body>
        <!-- ════════════════════════════════════════════
             NAV
        ════════════════════════════════════════════ -->
        <nav id="nav">
            <a href="/vios.science/" class="nav-logo">VIOS<span>.</span></a>
            <ul class="nav-links" id="nav-links">
                <li><a href="/vios.science/research">Research</a></li>
                <li><a href="/vios.science/team">Team</a></li>
                <li>
                    <a href="/vios.science/publications">Publications</a>
                </li>
                <li><a href="/vios.science/code">Code &amp; Data</a></li>
                <li><a href="/vios.science/tutorials">Tutorials</a></li>
                <li><a href="/vios.science/news">News</a></li>
                <li><a href="/vios.science/join">Join Us</a></li>
            </ul>
            <div class="nav-right">
                <button
                    class="theme-toggle"
                    id="theme-toggle"
                    aria-label="Toggle light/dark theme"
                >
                    <!-- Moon icon (shown in dark mode) -->
                    <svg
                        class="icon-moon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"
                        ></path>
                    </svg>
                    <!-- Sun icon (shown in light mode) -->
                    <svg
                        class="icon-sun"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
                        ></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                </button>
                <button
                    class="nav-menu-btn"
                    id="nav-menu-btn"
                    aria-label="Toggle menu"
                    aria-expanded="false"
                >
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        <slot />

        <!-- ════════════════════════════════════════════
             AFFILIATIONS
        ════════════════════════════════════════════ -->
        <div class="affil-bar">
            <span class="affil-label">Affiliations</span>
            <div class="affil-list">
                <a href="https://www.ed.ac.uk/" class="affil-name" target="_blank" rel="noopener noreferrer">The University of Edinburgh</a>
                <a href="https://www.chai.ac.uk/" class="affil-name" target="_blank" rel="noopener noreferrer">CHAI AI Hub</a>
                <a href="https://research.eu.medical.canon/" class="affil-name" target="_blank" rel="noopener noreferrer">Canon Medical Research</a>
                <a href="https://phenomuk.org/" class="affil-name" target="_blank" rel="noopener noreferrer">PhenomUK</a>
            </div>
        </div>

        <!-- ════════════════════════════════════════════
             FOOTER
        ════════════════════════════════════════════ -->
        <footer>
            <div>
                <a href="/vios.science/" class="f-logo">VIOS<span>.</span></a>
                <p class="f-tagline">
                    AI for Life Sciences.<br />
                    University of Edinburgh.
                </p>
            </div>
            <div>
                <h4 class="f-col-label">Explore</h4>
                <ul class="f-links">
                    <li><a href="/vios.science/research">Research</a></li>
                    <li><a href="/vios.science/team">Team</a></li>
                    <li>
                        <a href="/vios.science/publications">Publications</a>
                    </li>
                    <li><a href="/vios.science/tutorials">Tutorials</a></li>
                </ul>
            </div>
            <div>
                <h4 class="f-col-label">Connect</h4>
                <ul class="f-links">
                    <li><a href="/vios.science/join">Join the Lab</a></li>
                    <li>
                        <a href="https://twitter.com/SotiriosA" target="_blank"
                            >Twitter / X</a
                        >
                    </li>
                    <li><a href="mailto:vios@ed.ac.uk">Contact Us</a></li>
                </ul>
            </div>
            <div class="f-bottom">
                <span class="f-copy"
                    >© 2026 VIOS Collaboratory.<br />Institute for Digital Communications<br />The School of Engineering<br />The University of Edinburgh</span
                >
                <img src="/vios.science/assets/images/edinburgh.svg" alt="The University of Edinburgh" class="f-uoe-logo" />
            </div>
        </footer>

        <script is:inline>
            // Nav scroll
            const nav = document.getElementById("nav");
            window.addEventListener("scroll", () => {
                nav.classList.toggle("scrolled", window.scrollY > 60);
            });

            // Theme toggle logic
            document
                .getElementById("theme-toggle")
                .addEventListener("click", () => {
                    const isDark =
                        document.documentElement.classList.contains("light"); // If light class is present, we are turning dark

                    if (isDark) {
                        // Switch to dark
                        document.documentElement.classList.remove("light");
                        window.localStorage.setItem("vios-theme", "dark");
                    } else {
                        // Switch to light
                        document.documentElement.classList.add("light");
                        window.localStorage.setItem("vios-theme", "light");
                    }

                    // Dispatch event so ThreeJS or others can listen
                    window.dispatchEvent(new Event("theme-changed"));
                });

            // Scroll reveal
            const io = new IntersectionObserver(
                (entries) => {
                    entries.forEach((e) => {
                        if (e.isIntersecting) e.target.classList.add("vis");
                    });
                },
                { threshold: 0 },
            );

            setTimeout(() => {
                document
                    .querySelectorAll(".reveal, .stagger")
                    .forEach((el) => io.observe(el));
            }, 100);

            // Re-run observer after Astro view transitions
            document.addEventListener("astro:page-load", () => {
                document
                    .querySelectorAll(".reveal, .stagger")
                    .forEach((el) => io.observe(el));
            });

            // Mobile nav toggle
            const menuBtn = document.getElementById("nav-menu-btn");
            const navEl = document.getElementById("nav");
            if (menuBtn && navEl) {
                menuBtn.addEventListener("click", () => {
                    const isOpen = navEl.classList.toggle("nav-open");
                    menuBtn.classList.toggle("open", isOpen);
                    menuBtn.setAttribute("aria-expanded", String(isOpen));
                });
                document.querySelectorAll(".nav-links a").forEach((link) => {
                    link.addEventListener("click", () => {
                        navEl.classList.remove("nav-open");
                        menuBtn.classList.remove("open");
                        menuBtn.setAttribute("aria-expanded", "false");
                    });
                });
            }
        </script>
    </body>
</html>
<style is:global>
    /* ═══════════════════════════════════════════════
           THEME TOKENS
        ═══════════════════════════════════════════════ */
    :root {
        --bg: #060d1a;
        --bg2: #0c1d34;
        --bg3: #112240;
        --accent: #00d4aa;
        --accent2: #5b8ef0;
        --accent-alpha: rgba(0, 212, 170, 0.4);
        --text: #dde8f5;
        --muted: #8ca3bc;
        --dim: #547393;
        --border: rgba(0, 212, 170, 0.2);
        --border2: rgba(255, 255, 255, 0.1);
        --shadow: rgba(0, 0, 0, 0.4);
        --hero-bg: #060d1a;
        --btn-text: #060d1a;
    }

    html.light {
        --bg: #f4f7fc;
        --bg2: #e6eef8;
        --bg3: #d8e6f4;
        --accent: #006f56;
        --accent2: #1e51b3;
        --accent-alpha: rgba(0, 111, 86, 0.4);
        --text: #0d1b2e;
        --muted: #344c66;
        --dim: #5c799a;
        --border: rgba(0, 111, 86, 0.2);
        --border2: rgba(0, 0, 0, 0.12);
        --shadow: rgba(0, 0, 0, 0.1);
        --hero-bg: #e8f0fb;
        --btn-text: #f4f7fc;
    }

    /* ═══════════════════════════════════════════════
           RESET & BASE
        ═══════════════════════════════════════════════ */
    *,
    *::before,
    *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    html {
        scroll-behavior: smooth;
        font-size: 18px;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: "Outfit", sans-serif;
        overflow-x: hidden;
        transition:
            background 0.35s ease,
            color 0.35s ease;
    }

    .prose a {
        color: var(--accent);
        text-decoration: none;
        box-shadow: 0 1px 0 var(--accent-alpha);
        transition:
            box-shadow 0.2s,
            color 0.2s;
    }
    .prose a:hover {
        box-shadow: 0 2px 0 var(--accent);
    }

    /* ═══════════════════════════════════════════════
           NAV
        ═══════════════════════════════════════════════ */
    #nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        padding: 1.5rem 5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.4s ease;
    }
    #nav.scrolled {
        background: rgba(6, 13, 26, 0.93);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        padding: 0.9rem 5rem;
        border-bottom: 1px solid var(--border);
    }
    html.light #nav.scrolled {
        background: rgba(244, 247, 252, 0.93);
    }

    .nav-logo {
        font-family: "Spectral", serif;
        font-size: 1.6rem;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
        letter-spacing: 0.03em;
    }
    .nav-logo span {
        color: var(--accent);
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .nav-links {
        display: flex;
        gap: 2.2rem;
        list-style: none;
    }

    /* Hamburger button */
    .nav-menu-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        background: none;
        border: 1px solid var(--border2);
        color: var(--muted);
        cursor: pointer;
        width: 36px;
        height: 36px;
        border-radius: 2px;
        padding: 4px;
        transition: border-color 0.2s;
    }
    .nav-menu-btn:hover {
        border-color: var(--accent);
    }
    .nav-menu-btn span {
        display: block;
        width: 18px;
        height: 1.5px;
        background: var(--text);
        transition: all 0.3s ease;
        margin: 0 auto;
    }
    .nav-menu-btn.open span:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
    }
    .nav-menu-btn.open span:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }
    .nav-menu-btn.open span:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
    }
    .nav-links a {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        transition: color 0.2s;
    }
    .nav-links a:hover {
        color: var(--accent);
    }

    /* Theme toggle */
    .theme-toggle {
        background: none;
        border: 1px solid var(--border2);
        color: var(--muted);
        cursor: pointer;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 2px;
        transition:
            border-color 0.2s,
            color 0.2s;
    }
    .theme-toggle:hover {
        border-color: var(--accent);
        color: var(--accent);
    }
    .theme-toggle svg {
        width: 16px;
        height: 16px;
    }
    .icon-sun {
        display: none;
    }
    html.light .icon-moon {
        display: none;
    }
    html.light .icon-sun {
        display: block;
    }

    /* ═══════════════════════════════════════════════
           HERO
        ═══════════════════════════════════════════════ */
    #hero {
        position: relative;
        height: 100vh;
        min-height: 700px;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: var(--hero-bg);
        transition: background 0.35s ease;
    }

    #hero-3d {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
    }

    .hero-veil {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background: linear-gradient(
            90deg,
            var(--hero-bg) 0%,
            rgba(6, 13, 26, 0.82) 25%,
            rgba(6, 13, 26, 0.2) 55%,
            transparent 75%
        );
        transition: background 0.35s ease;
    }
    html.light .hero-veil {
        background: linear-gradient(
            90deg,
            var(--hero-bg) 0%,
            rgba(232, 240, 251, 0.88) 25%,
            rgba(232, 240, 251, 0.2) 55%,
            transparent 75%
        );
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 0 8rem;
        max-width: 820px;
    }

    .hero-eyebrow {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-bottom: 2rem;
        opacity: 0;
        animation: fadeUp 0.8s ease 0.3s forwards;
    }
    .eyebrow-line {
        width: 32px;
        height: 1px;
        background: var(--accent);
        flex-shrink: 0;
    }
    .eyebrow-text {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.65rem;
        font-weight: 300;
        color: var(--accent);
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }

    .hero-title {
        font-family: "Spectral", serif;
        font-size: clamp(5.5rem, 11vw, 9.5rem);
        font-weight: 300;
        line-height: 0.9;
        color: var(--text);
        letter-spacing: -0.01em;
        opacity: 0;
        animation: fadeUp 0.9s ease 0.5s forwards;
    }
    .hero-sub {
        font-family: "Spectral", serif;
        font-size: clamp(1.2rem, 2.5vw, 1.75rem);
        font-weight: 300;
        font-style: italic;
        color: var(--muted);
        letter-spacing: 0.05em;
        margin-bottom: 2rem;
        opacity: 0;
        animation: fadeUp 0.8s ease 0.65s forwards;
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        background: rgba(0, 212, 170, 0.06);
        border: 1px solid rgba(0, 212, 170, 0.2);
        padding: 0.38rem 0.95rem;
        margin-bottom: 2.5rem;
        opacity: 0;
        animation: fadeUp 0.8s ease 0.8s forwards;
    }
    html.light .hero-pill {
        background: rgba(0, 137, 106, 0.07);
        border-color: rgba(0, 137, 106, 0.22);
    }
    .pill-greek {
        font-family: "Spectral", serif;
        font-size: 1.1rem;
        color: var(--accent);
    }
    .pill-dot {
        color: var(--dim);
        font-size: 0.65rem;
    }
    .pill-en {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.6rem;
        color: var(--muted);
        letter-spacing: 0.13em;
        text-transform: uppercase;
    }

    .hero-desc {
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--muted);
        max-width: 490px;
        margin-bottom: 2.8rem;
        font-weight: 400;
        opacity: 0;
        animation: fadeUp 0.8s ease 0.95s forwards;
    }
    .hero-desc strong {
        color: var(--text);
        font-weight: 600;
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        opacity: 0;
        animation: fadeUp 0.8s ease 1.1s forwards;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        background: var(--accent);
        color: var(--btn-text);
        padding: 0.85rem 2rem;
        font-family: "Outfit", sans-serif;
        font-size: 0.73rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        clip-path: polygon(
            0 0,
            calc(100% - 8px) 0,
            100% 8px,
            100% 100%,
            0 100%
        );
        transition: all 0.25s ease;
    }
    .btn-primary:hover {
        filter: brightness(1.12);
        transform: translateY(-2px);
        box-shadow: 0 10px 32px rgba(0, 212, 170, 0.32);
    }
    html.light .btn-primary:hover {
        box-shadow: 0 10px 32px rgba(0, 137, 106, 0.28);
    }

    .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        background: transparent;
        color: var(--text);
        padding: 0.85rem 2rem;
        font-family: "Outfit", sans-serif;
        font-size: 0.73rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        border: 1px solid var(--border2);
        transition: all 0.25s ease;
    }
    .btn-secondary:hover {
        border-color: var(--accent);
        color: var(--accent);
        transform: translateY(-2px);
    }

    .scroll-cue {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        opacity: 0;
        animation: fadeIn 1s ease 1.6s forwards;
    }
    .scroll-line {
        width: 1px;
        height: 50px;
        background: linear-gradient(to bottom, var(--accent), transparent);
        animation: scrollPulse 2s ease-in-out infinite;
    }
    .scroll-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.56rem;
        color: var(--dim);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        writing-mode: vertical-rl;
    }

    /* ═══════════════════════════════════════════════
           MISSION INTERLUDE
        ═══════════════════════════════════════════════ */
    #mission {
        padding: 8rem;
        background: var(--bg2);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        text-align: center;
        position: relative;
        overflow: hidden;
        transition: background 0.35s ease;
    }
    #mission::before {
        content: "Βίος";
        position: absolute;
        pointer-events: none;
        user-select: none;
        font-family: "Spectral", serif;
        font-size: 20rem;
        font-weight: 300;
        color: rgba(0, 212, 170, 0.03);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        white-space: nowrap;
    }
    html.light #mission::before {
        color: rgba(0, 137, 106, 0.04);
    }

    .mission-quote {
        font-family: "Spectral", serif;
        font-size: clamp(1.6rem, 3vw, 2.5rem);
        font-weight: 300;
        font-style: italic;
        line-height: 1.5;
        color: var(--text);
        max-width: 800px;
        margin: 0 auto 1.6rem;
        position: relative;
    }
    .mission-quote em {
        color: var(--accent);
        font-style: normal;
    }
    .mission-attr {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.62rem;
        color: var(--dim);
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    /* ═══════════════════════════════════════════════
           SECTION COMMON
        ═══════════════════════════════════════════════ */
    section {
        padding: 6.5rem 8rem;
    }
    #hero {
        padding: 0;
    }

    .s-head {
        margin-bottom: 3.5rem;
    }
    .s-eyebrow {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 0.8rem;
    }
    .s-eyebrow-line {
        width: 20px;
        height: 1px;
        background: var(--accent);
        flex-shrink: 0;
    }
    .s-eyebrow-text {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.62rem;
        color: var(--accent);
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }
    .s-title {
        font-family: "Spectral", serif;
        font-size: clamp(2.2rem, 3.8vw, 3.2rem);
        font-weight: 300;
        line-height: 1.15;
        color: var(--text);
    }
    .s-title em {
        color: var(--accent);
        font-style: italic;
    }

    /* ═══════════════════════════════════════════════
           NEWS
        ═══════════════════════════════════════════════ */
    #news {
        background: var(--bg);
        transition: background 0.35s ease;
    }

    .news-grid {
        display: grid;
