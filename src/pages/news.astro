---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getSortedNews } from "../utils/news";

const allNews = await getCollection("news");
const sortedNews = getSortedNews(allNews);

const newsByYear = sortedNews.reduce(
    (acc, current) => {
        const year = current.parsedDate.getFullYear();
        if (!acc[year]) acc[year] = [];
        acc[year].push(current);
        return acc;
    },
    {} as Record<number, any[]>,
);

const years = Object.keys(newsByYear)
    .map(Number)
    .sort((a, b) => b - a);
---

<Layout title="News - VIOS Collaboratory">
    <section class="page-header" style="padding: 10rem 8rem 4rem;">
        <div class="s-head">
            <div class="s-eyebrow">
                <div class="s-eyebrow-line"></div>
                <span class="s-eyebrow-text">Explore</span>
            </div>
            <h1 class="s-title">Latest <em>News</em></h1>
        </div>
    </section>

    <div class="news-container stagger">
        {
            years.map((year) => (
                <div class="year-group">
                    <h2 class="year-title">{year}</h2>
                    <div class="news-list">
                        {newsByYear[year].map(async (item) => {
                            const { Content } = await item.render();
                            return (
                                <article class="news-item">
                                    <div class="news-meta">
                                        <span class="news-date">
                                            {item.parsedDate.toLocaleDateString(
                                                "en-US",
                                                {
                                                    month: "short",
                                                    day: "numeric",
                                                    year: "numeric",
                                                },
                                            )}
                                        </span>
                                    </div>
                                    <div class="news-content">
                                        <h3 class="news-item-title">
                                            {item.data.title}
                                        </h3>
                                        <div class="prose">
                                            <Content />
                                        </div>
                                    </div>
                                </article>
                            );
                        })}
                    </div>
                </div>
            ))
        }
    </div>
</Layout>

<style>
    .page-header {
        padding: 8rem 8rem 2rem;
    }
    .news-container {
        padding: 0 8rem 6rem;
        max-width: 1600px;
    }
    .year-group {
        margin-bottom: 4rem;
        display: flex;
        gap: 4rem;
    }
    .year-title {
        font-family: "Spectral", serif;
        font-size: 3.5rem;
        font-weight: 300;
        color: var(--accent);
        opacity: 0.3;
        margin: 0;
        line-height: 1;
        position: sticky;
        top: 6rem;
        align-self: flex-start;
    }
    .news-list {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        flex: 1;
        padding-top: 0.5rem;
    }
    .news-item {
        background: var(--bg2);
        border: 1px solid var(--border);
        padding: 2.5rem;
        border-radius: 8px;
        transition:
            transform 0.3s,
            border-color 0.3s,
            background 0.35s ease;
        position: relative;
    }
    .news-item:hover {
        transform: translateY(-4px);
        border-color: rgba(0, 212, 170, 0.4);
        background: var(--bg3);
    }
    .news-item::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: var(--accent);
        transform: scaleY(0);
        transform-origin: top;
        transition: transform 0.4s ease;
        border-radius: 8px 0 0 8px;
    }
    .news-item:hover::before {
        transform: scaleY(1);
    }
    .news-meta {
        margin-bottom: 1rem;
    }
    .news-date {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.8rem;
        color: var(--accent);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        background: rgba(0, 212, 170, 0.07);
        border: 1px solid rgba(0, 212, 170, 0.2);
        padding: 0.25rem 0.6rem;
        border-radius: 4px;
    }
    html.light .news-date {
        background: rgba(0, 137, 106, 0.07);
        border: 1px solid rgba(0, 137, 106, 0.2);
    }
    .news-item-title {
        font-family: "Outfit", sans-serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 1rem 0;
        line-height: 1.3;
    }
    .prose {
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.7;
    }
    .prose :global(a) {
        color: var(--accent);
        text-decoration: none;
        box-shadow: 0 1px 0 rgba(0, 212, 170, 0.4);
        transition:
            box-shadow 0.2s,
            color 0.2s;
    }
    .prose :global(a:hover) {
        box-shadow: 0 2px 0 var(--accent);
    }
    .prose :global(p) {
        margin-bottom: 1rem;
    }
    .prose :global(p:last-child) {
        margin-bottom: 0;
    }
    .prose :global(h1),
    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4),
    .prose :global(h5),
    .prose :global(h6) {
        color: var(--text);
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        font-family: "Outfit", sans-serif;
    }

    @media (max-width: 900px) {
        .page-header {
            padding: 7rem 3rem 2rem;
        }
        .news-container {
            padding: 0 3rem 4rem;
        }
        .year-group {
            flex-direction: column;
            gap: 1.5rem;
        }
        .year-title {
            position: static;
            font-size: 2.5rem;
        }
    }

    @media (max-width: 600px) {
        .page-header {
            padding: 6rem 1.5rem 1.5rem;
        }
        .news-container {
            padding: 0 1.5rem 3rem;
        }
        .news-item {
            padding: 1.5rem;
        }
    }
</style>
