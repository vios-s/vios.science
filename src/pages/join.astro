---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";

const joinPage = await getEntry("pages", "join_us");
if (!joinPage) {
    throw new Error("Join Page not found in content/pages/join_us.mdx");
}
const { Content, headings } = await joinPage.render();
---

<Layout title={`${joinPage.data.title} - VIOS Collaboratory`}>
    <div class="tutorial-wrapper">
        <article class="tutorial-content markdown-body">
            <header class="tutorial-header">
                <div class="th-eyebrow">
                    <div class="s-eyebrow-line"></div>
                    <span class="s-eyebrow-text">Careers & Opportunities</span>
                </div>
                <h1 class="th-title">{joinPage.data.title}</h1>
            </header>

            <Content />
        </article>

        <aside class="toc-sidebar">
            <div class="toc-sticky">
                <h3>ON THIS PAGE</h3>
                <nav>
                    <ul>
                        {
                            headings
                                .filter((h) => {
                                    return h.depth === 2;
                                })
                                .map((heading) => (
                                    <li>
                                        <a href={`#${heading.slug}`}>
                                            {heading.text}
                                        </a>
                                    </li>
                                ))
                        }
                    </ul>
                </nav>
            </div>
        </aside>
    </div>
</Layout>

<style>
    .tutorial-wrapper {
        padding: 8rem 8rem;
        max-width: none;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 5rem;
        align-items: start;
    }

    .toc-sidebar {
        position: sticky;
        top: 120px;
        background: var(--bg2);
        padding: 2rem;
        border: 1px solid var(--border);
        border-radius: 4px;
    }

    .toc-sticky h3 {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.8rem;
        color: var(--accent);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid var(--border);
    }

    .toc-sticky nav {
        position: static !important;
        display: block !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .toc-sticky nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .toc-sticky nav a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
        line-height: 1.4;
        transition: color 0.2s;
        display: block;
    }

    .toc-sticky nav a:hover {
        color: var(--accent);
    }

    .tutorial-header {
        margin-bottom: 3rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 2rem;
    }

    .th-eyebrow {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .s-eyebrow-line {
        width: 30px;
        height: 1px;
        background: var(--accent);
    }

    .s-eyebrow-text {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.8rem;
        color: var(--accent);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .th-title {
        font-family: "Spectral", serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 400;
        color: var(--text);
        line-height: 1.1;
    }

    .tutorial-content :global(h1),
    .tutorial-content :global(h2),
    .tutorial-content :global(h3) {
        font-family: "Spectral", serif;
        color: var(--text);
        margin: 3rem 0 1.5rem;
        font-weight: 400;
        scroll-margin-top: 140px;
    }

    .tutorial-content :global(h1) {
        font-size: 2.5rem;
    }
    .tutorial-content :global(h2) {
        font-size: 2rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.5rem;
    }
    .tutorial-content :global(h3) {
        font-size: 1.5rem;
    }

    .tutorial-content :global(p) {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

    .tutorial-content :global(a) {
        color: var(--accent2);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
    }

    .tutorial-content :global(a:hover) {
        border-color: var(--accent2);
    }

    .tutorial-content :global(ul),
    .tutorial-content :global(ol) {
        margin-bottom: 2rem;
        padding-left: 2rem;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.8;
    }

    .tutorial-content :global(li) {
        margin-bottom: 0.8rem;
    }

    .tutorial-content :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 4px;
        margin: 1rem 0 3rem;
    }

    .tutorial-content :global(strong) {
        color: var(--text);
        font-weight: 600;
    }

    .tutorial-content :global(blockquote) {
        border-left: 4px solid var(--accent);
        padding-left: 1.5rem;
        margin: 2rem 0;
        font-style: italic;
        color: var(--dim);
    }

    .tutorial-content :global(del) {
        color: var(--dim);
        text-decoration-color: var(--muted);
    }

    @media (max-width: 900px) {
        .tutorial-wrapper {
            grid-template-columns: 1fr;
            padding: 8rem 2rem 4rem;
        }

        .toc-sidebar {
            position: relative;
            top: 0;
            margin-bottom: 2rem;
        }
    }
</style>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const tocLinks = document.querySelectorAll(".toc-sticky nav a");
        tocLinks.forEach((link) => {
            link.addEventListener("click", (e) => {
                const targetId = link.getAttribute("href").split("#")[1];
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    e.preventDefault();
                    const y =
                        targetElement.getBoundingClientRect().top +
                        window.scrollY -
                        140;
                    window.scrollTo({ top: y, behavior: "smooth" });
                    history.pushState(null, "", `#${targetId}`);
                }
            });
        });
    });
</script>
