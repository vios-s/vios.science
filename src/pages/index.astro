---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { base } from "../utils/base";
import { getSortedNews } from "../utils/news";
import { getSortedPublications, type Publication } from "../utils/publications";
import projectsData from "../data/projects.json";
import publicationsData from "../data/publications.yaml";

const allNews = await getCollection("news");
const topNews = getSortedNews(allNews).slice(0, 3);

const recentPublications = getSortedPublications(publicationsData as Publication[]).slice(0, 3);
const resolvePdfHref = (pdf?: string) => (pdf?.startsWith("/") ? base(pdf) : pdf);
---

<Layout title="VIOS Collaboratory — AI for Life Sciences">
    <section id="hero">
        <div id="hero-3d"></div>
        <div class="hero-veil"></div>

        <div class="hero-content">
            <div class="hero-eyebrow">
                <div class="eyebrow-line"></div>
                <span class="eyebrow-text"
                    >University of Edinburgh · CHAI AI Hub</span
                >
            </div>

            <h1 class="hero-title">VIOS</h1>
            <p class="hero-sub">Collaboratory</p>

            <div class="hero-pill">
                <span class="pill-greek">Βίος</span>
                <span class="pill-dot">·</span>
                <span class="pill-en">Life in Greek</span>
                <span class="pill-dot">·</span>
                <span class="pill-en">pronounced vEEOs</span>
            </div>

            <p class="hero-desc">
                We advance <strong>interdisciplinary AI</strong> — applying machine
                learning, computer vision, and causal reasoning to open challenges
                in
                <strong>medicine</strong>, <strong>agriculture</strong>, and the
                <strong>life sciences</strong>.
            </p>

            <div class="hero-ctas">
                <a href={base('/research')} class="btn-primary">
                    Explore Research
                    <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                        <path
                            d="M1 7H13M7 1L13 7L7 13"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </a>
                <a href={base('/team')} class="btn-secondary"
                    >Meet the Team</a
                >
            </div>
        </div>

        <div class="scroll-cue">
            <div class="scroll-line"></div>
            <span class="scroll-label">Scroll</span>
        </div>
    </section>

    <div id="mission">
        <p class="mission-quote reveal">
            "Life is central to our mission — with advances in AI, computer
            vision and inverse problems, we address <em>societal challenges</em> by
            solving key problems in the life and natural sciences."
        </p>
        <p class="mission-attr">
            — Sotirios A. Tsaftaris · Chair in Machine Learning &amp; Computer
            Vision
        </p>
    </div>

    <section id="news">
        <div class="s-head reveal">
            <div class="s-eyebrow">
                <div class="s-eyebrow-line"></div>
                <span class="s-eyebrow-text">Latest Updates</span>
            </div>
            <h2 class="s-title">News &amp; <em>highlights</em></h2>
        </div>

        <div class="news-grid stagger">
            {
                topNews.map(async (item) => {
                    const { Content } = await item.render();
                    return (
                        <div class="n-card">
                            <span class="n-tag">
                                {item.parsedDate.toLocaleDateString("en-US", {
                                    month: "short",
                                    day: "numeric",
                                    year: "numeric",
                                })}
                            </span>
                            <h3 class="n-title">{item.data.title}</h3>
                            <div class="n-desc prose">
                                <Content />
                            </div>
                        </div>
                    );
                })
            }
        </div>

        <div
            class="publication-more"
            style="margin-top: 3rem; margin-bottom: 4rem; display: flex; justify-content: center;"
        >
            <a href={base('/news')} class="btn-secondary">View All News</a>
        </div>

        <div
            class="social-feed reveal"
            style="width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; box-sizing: border-box;"
        >
            <script src="https://elfsightcdn.com/platform.js" async></script>
            <div
                class="elfsight-app-0afc190d-9c93-4731-853c-d9937beb75d2"
                data-elfsight-app-lazy
            >
            </div>
        </div>
    </section>

    <section id="research">
        <div class="s-head reveal">
            <div class="s-eyebrow">
                <div class="s-eyebrow-line"></div>
                <span class="s-eyebrow-text">Research Focus</span>
            </div>
            <h2 class="s-title">Where AI meets<br /><em>sciences</em></h2>
        </div>

        <div class="research-grid stagger">
            <div class="r-card" style="--card-color:#00d4aa">
                <span class="r-num">01</span>
                <span class="r-icon">🫀</span>
                <h3 class="r-title">Healthcare Systems</h3>
                <p class="r-desc">
                    Medical imaging and image analysis with a focus on
                    representation learning — doing more with less through
                    semi-supervised, multi-task, and multi-modal approaches.
                    Active work on cardiac MRI, digital twin surgery, and
                    AI-assisted clinical decision making.
                </p>
                <div class="r-tags">
                    <span class="tag">Cardiac MRI</span>
                    <span class="tag">Digital Twin Surgery</span>
                    <span class="tag">Multi-modal</span>
                    <span class="tag">Foundation Models</span>
                </div>
            </div>

            <div class="r-card" style="--card-color:#5b8ef0">
                <span class="r-num">02</span>
                <span class="r-icon">⚛️</span>
                <h3 class="r-title">Causal AI &amp; Fair Representations</h3>
                <p class="r-desc">
                    Disentangled representation learning, causal discovery, and
                    equivariant architectures to build AI that reasons rather
                    than correlates — enabling reliable, bias-aware predictions
                    in high-stakes domains. Central to the EPSRC CHAI Hub.
                </p>
                <div class="r-tags">
                    <span class="tag">Causal Discovery</span>
                    <span class="tag">Disentanglement</span>
                    <span class="tag">Bias Mitigation</span>
                    <span class="tag">CHAI Hub</span>
                </div>
            </div>

            <div class="r-card" style="--card-color:#a78bfa">
                <span class="r-num">03</span>
                <span class="r-icon">🌿</span>
                <h3 class="r-title">Sustainability &amp; Agriculture</h3>
                <p class="r-desc">
                    Computer vision for plant phenotypic trait estimation, crop
                    breeding, and disease resistance. Open data frameworks and
                    digital research infrastructure — including PhenomUK —
                    supporting sustainable global agriculture.
                </p>
                <div class="r-tags">
                    <span class="tag">Plant Phenotyping</span>
                    <span class="tag">PhenomUK</span>
                    <span class="tag">Open Data</span>
                    <span class="tag">Trait Estimation</span>
                </div>
            </div>

            <div class="r-card" style="--card-color:#f59e0b">
                <span class="r-num">04</span>
                <span class="r-icon">⚡</span>
                <h3 class="r-title">AI for Energy &amp; Inverse Problems</h3>
                <p class="r-desc">
                    Virtual power plants, AI-driven grid resilience, and
                    data-driven materials innovation for the wearable artificial
                    kidney. Addressing complex inverse problems in energy,
                    environmental, and biomedical sciences.
                </p>
                <div class="r-tags">
                    <span class="tag">Energy AI</span>
                    <span class="tag">Virtual Power Plant</span>
                    <span class="tag">Inverse Problems</span>
                    <span class="tag">Wearable Kidney</span>
                </div>
            </div>
        </div>

        <p class="projects-label">Active &amp; Recent Funded Projects</p>
        <div class="projects-list stagger">
            {
                projectsData.ongoing.map((project: any) => (
                    <div class="project-item">
                        <span class="project-funder">
                            {project.short_funder}
                        </span>
                        <span class="project-name">{project.title}</span>
                    </div>
                ))
            }
        </div>
    </section>

    <section id="publications">
        <div class="s-head reveal">
            <div class="s-eyebrow">
                <div class="s-eyebrow-line"></div>
                <span class="s-eyebrow-text">Selected Work</span>
            </div>
            <h2 class="s-title">Recent <em>publications</em></h2>
        </div>

        <div class="publication-cards stagger">
            {
                recentPublications.map((publication) => (
                    <div class="publication-card">
                        {publication.image ? (
                            <img
                                class="publication-card-img"
                                src={base(publication.image)}
                                alt={`${publication.title} teaser`}
                                loading="lazy"
                            />
                        ) : (
                            <div class="publication-card-img" style="min-height:160px;background:var(--bg3)" />
                        )}
                        <div class="publication-card-body">
                            <span class="publication-card-venue">{publication.venue}</span>
                            <p class="publication-card-title">{publication.title}</p>
                            <p class="publication-card-authors">{publication.authors}</p>
                        </div>
                        <div class="publication-card-footer">
                            {publication.pdf && (
                                <a
                                    href={resolvePdfHref(publication.pdf)}
                                    class="publication-card-link"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    PDF →
                                </a>
                            )}
                            {publication.code && (
                                <a
                                    href={publication.code}
                                    class="publication-card-link"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    Code →
                                </a>
                            )}
                            {publication.website && (
                                <a
                                    href={publication.website}
                                    class="publication-card-link"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    Website →
                                </a>
                            )}
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="publication-more">
            <a href={base('/publications')} class="btn-secondary"
                >View All Publications</a
            >
        </div>
    </section>

    <script src="../scripts/heroLoader.ts"></script>
</Layout>
