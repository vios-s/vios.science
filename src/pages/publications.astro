---
import Layout from "../layouts/Layout.astro";
import { getSortedPublications, type Publication } from "../utils/publications";
import publicationsData from "../data/publications.yaml";
import publicationPlaceholderLightSvg from "../assets/placeholders/publication-placeholder-light.svg?raw";

const publications = getSortedPublications(publicationsData as Publication[]);
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const publicationsJson = JSON.stringify(
    publications.map((publication) => ({
        ...publication,
        image: publication.image ? `${baseUrl}/${publication.image.replace(/^\//, "")}` : null,
    }))
);
---

<Layout title="Publications - VIOS Collaboratory">
    <section class="page-header">
        <div class="s-head">
            <div class="s-eyebrow">
                <div class="s-eyebrow-line"></div>
                <span class="s-eyebrow-text">Our Output</span>
            </div>
            <h1 class="s-title">Latest <em>publications</em></h1>
        </div>
    </section>

    <div class="pub-container">
        <div class="pub-search-wrap">
            <input
                id="pub-search"
                class="pub-search"
                type="search"
                placeholder="Search by title, author, or venue…"
                aria-label="Search publications"
            />
        </div>

        <div id="pub-cards" class="pub-cards"></div>

        <p id="pub-empty" class="pub-empty" hidden>No publications match your search.</p>

        <div id="pub-sentinel" class="pub-sentinel"></div>
    </div>
</Layout>

<script define:vars={{ publicationsJson, publicationPlaceholderLightSvg }}>
    const PAGE_SIZE = 20;
    const ALL_PUBLICATIONS = JSON.parse(publicationsJson);

    let filtered = ALL_PUBLICATIONS;
    let offset = 0;
    let lastRenderedYear = null;

    const grid = document.getElementById("pub-cards");
    const empty = document.getElementById("pub-empty");
    const sentinel = document.getElementById("pub-sentinel");

    function escape(str) {
        return (str ?? "").replace(/[&<>"']/g, (character) =>
            ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[character])
        );
    }

    function truncateAuthors(authors, max = 8) {
        const parts = (authors ?? "").split(",").map((author) => author.trim()).filter(Boolean);
        if (parts.length <= max) return authors ?? "";
        return parts.slice(0, max).join(", ") + ", …";
    }

    function publicationYear(publication) {
        if (!publication?.date) return "Unknown";
        const year = new Date(publication.date).getFullYear();
        return Number.isNaN(year) ? "Unknown" : String(year);
    }

    const PLACEHOLDER_LIGHT = publicationPlaceholderLightSvg;

    function cardHTML(publication) {
        const media = publication.image
            ? `<img class="pub-card-img" src="${escape(publication.image)}" alt="Paper Teaser" loading="lazy" />`
            : `<div class="pub-card-img-placeholder" role="img" aria-label="No preview available">${PLACEHOLDER_LIGHT}</div>`;
        const links = [
            publication.code    ? `<a href="${escape(publication.code)}"    class="pub-card-link" target="_blank" rel="noopener noreferrer">Code →</a>` : "",
            publication.website ? `<a href="${escape(publication.website)}" class="pub-card-link" target="_blank" rel="noopener noreferrer">Website →</a>` : "",
        ].join("");
        const footer = links ? `<div class="pub-card-footer">${links}</div>` : "";
        return `
            <div class="pub-card pub-card-new">
                ${media}
                <div class="pub-card-body">
                    <span class="pub-card-venue">${escape(publication.venue)}</span>
                    <p class="pub-card-title">${escape(publication.title)}</p>
                    <p class="pub-card-authors">${escape(truncateAuthors(publication.authors))}</p>
                </div>
                ${footer}
            </div>`;
    }

    function renderChunk() {
        const chunk = filtered.slice(offset, offset + PAGE_SIZE);
        if (chunk.length === 0) return;
        const frag = document.createDocumentFragment();
        chunk.forEach((publication) => {
            const year = publicationYear(publication);
            if (year !== lastRenderedYear) {
                const heading = document.createElement("h2");
                heading.className = "pub-year-heading";
                heading.textContent = year;
                frag.appendChild(heading);
                lastRenderedYear = year;
            }
            const cardContainer = document.createElement("div");
            cardContainer.innerHTML = cardHTML(publication);
            frag.appendChild(cardContainer.firstElementChild);
        });
        grid.appendChild(frag);
        // Trigger fade-in on next frame
        requestAnimationFrame(() => {
            grid.querySelectorAll(".pub-card-new").forEach((el) => {
                el.classList.remove("pub-card-new");
            });
        });
        offset += chunk.length;
    }

    function reset() {
        grid.innerHTML = "";
        offset = 0;
        lastRenderedYear = null;
        empty.hidden = filtered.length > 0;
        renderChunk();
    }

    // Initial render
    reset();

    // Search
    document.getElementById("pub-search").addEventListener("input", (event) => {
        const searchQuery = event.target.value.trim().toLowerCase();
        if (!searchQuery) {
            filtered = ALL_PUBLICATIONS;
        } else {
            filtered = ALL_PUBLICATIONS.filter(
                (publication) =>
                    (publication.title   ?? "").toLowerCase().includes(searchQuery) ||
                    (publication.authors ?? "").toLowerCase().includes(searchQuery) ||
                    (publication.venue   ?? "").toLowerCase().includes(searchQuery)
            );
        }
        reset();
    });

    // Infinite scroll
    const observer = new IntersectionObserver(
        (entries) => {
            if (entries[0].isIntersecting && offset < filtered.length) {
                renderChunk();
            }
        },
        { rootMargin: "200px" }
    );
    observer.observe(sentinel);
</script>

<style>
    .page-header {
        padding: 8rem 8rem 2rem;
    }
    .pub-container {
        padding: 0 8rem 6rem;
    }

    .pub-search-wrap {
        display: flex;
        align-items: center;
        max-width: 800px;
        margin: 0 auto 1.5rem;
    }
    .pub-search {
        flex: 1;
        background: var(--bg2);
        border: 1px solid var(--border);
        color: var(--text);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        padding: 0.65rem 1rem;
        outline: none;
        transition: border-color 0.2s, background 0.2s;
    }
    .pub-search::placeholder {
        color: var(--muted);
    }
    .pub-search:focus {
        border-color: rgba(0, 212, 170, 0.5);
        background: var(--bg3);
    }
    /* hide the browser's built-in × button so style stays consistent */
    .pub-search::-webkit-search-cancel-button { display: none; }

    .pub-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    :global(.pub-card-new) {
        opacity: 0;
    }
    :global(.pub-card:not(.pub-card-new)) {
        animation: fadeUp 0.3s ease both;
    }
    :global(.pub-year-heading) {
        grid-column: 1 / -1;
        margin: 1.5rem 0 0.25rem;
        font-family: "Outfit", sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0.02em;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.45rem;
    }
    :global(.pub-year-heading:first-child) {
        margin-top: 0;
    }

    .pub-empty {
        text-align: center;
        padding: 3rem 0;
        color: var(--muted);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
    }
    .pub-sentinel {
        height: 1px;
    }

    :global(.pub-card) {
        background: var(--bg2);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        transition:
            transform 0.3s,
            border-color 0.3s,
            background 0.35s ease;
        overflow: hidden;
    }
    :global(.pub-card:hover) {
        transform: translateY(-4px);
        border-color: rgba(0, 212, 170, 0.4);
        background: var(--bg3);
    }
    :global(.pub-card-img) {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-bottom: 1px solid var(--border);
    }
    :global(.pub-card-img-placeholder) {
        width: 100%;
        aspect-ratio: 16/9;
        border-bottom: 1px solid var(--border);
        overflow: hidden;
        display: block;
        line-height: 0;
    }
    :global(.pub-card-img-placeholder svg) {
        width: 100%;
        height: 100%;
        display: block;
    }
    :global(.pub-card-body) {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    :global(.pub-card-venue) {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        color: var(--accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    :global(.pub-card-title) {
        font-family: "Outfit", sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.35;
    }
    :global(.pub-card-authors) {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.4;
        margin-top: auto;
        padding-top: 0.5rem;
    }
    :global(.pub-card-footer) {
        padding: 0.85rem 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 1.25rem;
    }
    :global(.pub-card-link) {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.75rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.08em;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: color 0.2s;
    }
    :global(.pub-card-link:hover) {
        color: var(--accent);
    }

    @media (max-width: 900px) {
        .page-header {
            padding: 7rem 3rem 2rem;
        }
        .pub-container {
            padding: 0 3rem 4rem;
        }
    }

    @media (max-width: 600px) {
        .page-header {
            padding: 6rem 1.5rem 1.5rem;
        }
        .pub-container {
            padding: 0 1.5rem 3rem;
        }
        .pub-cards {
            grid-template-columns: 1fr;
        }
        .pub-search-wrap {
            max-width: 100%;
        }
    }
</style>
