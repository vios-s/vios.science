---
import Layout from "../layouts/Layout.astro";
import { getSortedPublications, type Publication } from "../utils/publications";
import publicationsData from "../data/publications.yaml";

const publications = getSortedPublications(publicationsData as Publication[]);
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const publicationsJson = JSON.stringify(
    publications.map((p) => ({
        ...p,
        image: p.image ? `${baseUrl}/${p.image.replace(/^\//, "")}` : null,
    }))
);
---

<Layout title="Publications - VIOS Collaboratory">
    <section class="page-header">
        <div class="s-head">
            <div class="s-eyebrow">
                <div class="s-eyebrow-line"></div>
                <span class="s-eyebrow-text">Our Output</span>
            </div>
            <h1 class="s-title">Latest <em>publications</em></h1>
        </div>
    </section>

    <div class="pub-container">
        <div class="pub-search-wrap">
            <input
                id="pub-search"
                class="pub-search"
                type="search"
                placeholder="Search by title, author, or venue…"
                aria-label="Search publications"
            />
        </div>

        <div id="pub-cards" class="pub-cards"></div>

        <p id="pub-empty" class="pub-empty" hidden>No publications match your search.</p>

        <div id="pub-sentinel" class="pub-sentinel"></div>
    </div>
</Layout>

<script define:vars={{ publicationsJson }}>
    const PAGE_SIZE = 20;
    const ALL_PUBLICATIONS = JSON.parse(publicationsJson);

    let filtered = ALL_PUBLICATIONS;
    let offset = 0;

    const grid    = document.getElementById("pub-cards");
    const empty   = document.getElementById("pub-empty");
    const sentinel = document.getElementById("pub-sentinel");

    function escape(str) {
        return (str ?? "").replace(/[&<>"']/g, (c) =>
            ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c])
        );
    }

    function cardHTML(p) {
        const media = p.image
            ? `<img class="pub-card-img" src="${escape(p.image)}" alt="Paper Teaser" loading="lazy" />`
            : `<div class="pub-card-img-placeholder"></div>`;
        const links = [
            p.code    ? `<a href="${escape(p.code)}"    class="pub-card-link" target="_blank" rel="noopener noreferrer">Code →</a>` : "",
            p.website ? `<a href="${escape(p.website)}" class="pub-card-link" target="_blank" rel="noopener noreferrer">Website →</a>` : "",
        ].join("");
        const footer = links ? `<div class="pub-card-footer">${links}</div>` : "";
        return `
            <div class="pub-card pub-card-new">
                ${media}
                <div class="pub-card-body">
                    <span class="pub-card-venue">${escape(p.venue)}</span>
                    <p class="pub-card-title">${escape(p.title)}</p>
                    <p class="pub-card-authors">${escape(p.authors)}</p>
                </div>
                ${footer}
            </div>`;
    }

    function renderChunk() {
        const chunk = filtered.slice(offset, offset + PAGE_SIZE);
        if (chunk.length === 0) return;
        const frag = document.createDocumentFragment();
        chunk.forEach((p) => {
            const tmp = document.createElement("div");
            tmp.innerHTML = cardHTML(p);
            frag.appendChild(tmp.firstElementChild);
        });
        grid.appendChild(frag);
        // Trigger fade-in on next frame
        requestAnimationFrame(() => {
            grid.querySelectorAll(".pub-card-new").forEach((el) => {
                el.classList.remove("pub-card-new");
            });
        });
        offset += chunk.length;
    }

    function reset() {
        grid.innerHTML = "";
        offset = 0;
        empty.hidden = filtered.length > 0;
        renderChunk();
    }

    // Initial render
    reset();

    // Search
    document.getElementById("pub-search").addEventListener("input", (e) => {
        const q = e.target.value.trim().toLowerCase();
        if (!q) {
            filtered = ALL_PUBLICATIONS;
        } else {
            filtered = ALL_PUBLICATIONS.filter(
                (p) =>
                    (p.title   ?? "").toLowerCase().includes(q) ||
                    (p.authors ?? "").toLowerCase().includes(q) ||
                    (p.venue   ?? "").toLowerCase().includes(q)
            );
        }
        reset();
    });

    // Infinite scroll
    const observer = new IntersectionObserver(
        (entries) => {
            if (entries[0].isIntersecting && offset < filtered.length) {
                renderChunk();
            }
        },
        { rootMargin: "200px" }
    );
    observer.observe(sentinel);
</script>

<style>
    .page-header {
        padding: 8rem 8rem 2rem;
    }
    .pub-container {
        padding: 0 8rem 6rem;
    }

    .pub-search-wrap {
        display: flex;
        align-items: center;
        max-width: 800px;
        margin: 0 auto 1.5rem;
    }
    .pub-search {
        flex: 1;
        background: var(--bg2);
        border: 1px solid var(--border);
        color: var(--text);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        padding: 0.65rem 1rem;
        outline: none;
        transition: border-color 0.2s, background 0.2s;
    }
    .pub-search::placeholder {
        color: var(--muted);
    }
    .pub-search:focus {
        border-color: rgba(0, 212, 170, 0.5);
        background: var(--bg3);
    }
    /* hide the browser's built-in × button so style stays consistent */
    .pub-search::-webkit-search-cancel-button { display: none; }

    .pub-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .pub-card-new {
        opacity: 0;
    }
    .pub-card:not(.pub-card-new) {
        animation: fadeUp 0.3s ease both;
    }

    .pub-empty {
        text-align: center;
        padding: 3rem 0;
        color: var(--muted);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
    }
    .pub-sentinel {
        height: 1px;
    }

    .pub-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        transition:
            transform 0.3s,
            border-color 0.3s,
            background 0.35s ease;
        overflow: hidden;
    }
    .pub-card:hover {
        transform: translateY(-4px);
        border-color: rgba(0, 212, 170, 0.4);
        background: var(--bg3);
    }
    .pub-card-img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-bottom: 1px solid var(--border);
    }
    .pub-card-img-placeholder {
        width: 100%;
        aspect-ratio: 16/9;
        background: var(--bg3);
        border-bottom: 1px solid var(--border);
    }
    .pub-card-body {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .pub-card-venue {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        color: var(--accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    .pub-card-title {
        font-family: "Outfit", sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.35;
    }
    .pub-card-authors {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.4;
        margin-top: auto;
        padding-top: 0.5rem;
    }
    .pub-card-footer {
        padding: 0.85rem 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 1.25rem;
    }
    .pub-card-link {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.75rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.08em;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: color 0.2s;
    }
    .pub-card-link:hover {
        color: var(--accent);
    }

    @media (max-width: 900px) {
        .page-header {
            padding: 7rem 3rem 2rem;
        }
        .pub-container {
            padding: 0 3rem 4rem;
        }
    }

    @media (max-width: 600px) {
        .page-header {
            padding: 6rem 1.5rem 1.5rem;
        }
        .pub-container {
            padding: 0 1.5rem 3rem;
        }
        .pub-cards {
            grid-template-columns: 1fr;
        }
        .pub-search-wrap {
            max-width: 100%;
        }
    }
</style>
